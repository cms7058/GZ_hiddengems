APP_NAME=Guizhou Hidden Gems API
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_DATABASE=gz_hidden_gems
MYSQL_USER=gz_hidden_gems
MYSQL_PASSWORD=replace-with-strong-app-password

DATABASE_URL=mysql+pymysql://gz_hidden_gems:replace-with-strong-app-password@mysql:3306/gz_hidden_gems?charset=utf8mb4
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-strong-admin-password

DEFAULT_LANGUAGE=zh-CN
COORDINATE_MASK_DECIMALS=2

DEBIAN_MIRROR=https://mirrors.cloud.tencent.com/debian
DEBIAN_SECURITY_MIRROR=https://mirrors.cloud.tencent.com/debian-security
PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
PIP_TRUSTED_HOST=mirrors.cloud.tencent.com

ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

MAP_PROVIDER=tencent
MAP_API_KEY=

AI_PROVIDER=
AI_API_KEY=
