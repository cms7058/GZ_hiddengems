APP_NAME=Guizhou Hidden Gems API
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_DATABASE=gz_hidden_gems
MYSQL_USER=gz_hidden_gems
MYSQL_PASSWORD=replace-with-strong-app-password

DATABASE_URL=mysql+pymysql://gz_hidden_gems:replace-with-strong-app-password@mysql:3306/gz_hidden_gems?charset=utf8mb4
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-strong-admin-password

DEFAULT_LANGUAGE=zh-CN
COORDINATE_MASK_DECIMALS=2

DEBIAN_MIRROR=https://mirrors.cloud.tencent.com/debian
DEBIAN_SECURITY_MIRROR=https://mirrors.cloud.tencent.com/debian-security
PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
PIP_TRUSTED_HOST=mirrors.cloud.tencent.com

ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_REGION=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_PUBLIC_BASE_URL=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
MEDIA_STORAGE_PROVIDER=local

MAP_PROVIDER=tencent
MAP_API_KEY=

# Tencent LBS route verification for check-in risk control. These can also be managed in the admin Check-ins page.
TENCENT_LBS_WEB_SERVICE_KEY=
TENCENT_LBS_BASE_URL=https://apis.map.qq.com
CHECKIN_ROUTE_WARN_RATIO=0.70
CHECKIN_ROUTE_SUSPICIOUS_RATIO=0.90
CHECKIN_WARNING_LIMIT=3
CHECKIN_SUSPICIOUS_LIMIT=5
CHECKIN_WATCH_LIMIT=10
CHECKIN_REPEAT_WINDOW_HOURS=48

WECHAT_MINI_APPID=
WECHAT_MINI_SECRET=

# QWeather / 和风天气
# 推荐生产使用 JWT：QWEATHER_API_HOST + QWEATHER_PROJECT_ID + QWEATHER_KEY_ID + QWEATHER_PRIVATE_KEY_FILE
QWEATHER_API_HOST=
QWEATHER_API_KEY=
QWEATHER_PROJECT_ID=
QWEATHER_KEY_ID=
QWEATHER_PRIVATE_KEY=
QWEATHER_PRIVATE_KEY_FILE=
QWEATHER_JWT_EXPIRE_SECONDS=900

AI_PROVIDER=
AI_API_KEY=
