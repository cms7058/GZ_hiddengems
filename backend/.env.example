APP_NAME=Guizhou Hidden Gems API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=mysql+pymysql://gz_hidden_gems:change-me@mysql:3306/gz_hidden_gems?charset=utf8mb4
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123456

DEFAULT_LANGUAGE=zh-CN
COORDINATE_MASK_DECIMALS=2

ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

MAP_PROVIDER=tencent
MAP_API_KEY=

# QWeather / 和风天气
# 推荐使用 JWT：填写 API Host、项目 ID、凭据 ID、Ed25519 私钥或私钥文件路径。
# 也可临时使用 API KEY：填写 QWEATHER_API_HOST 和 QWEATHER_API_KEY。
QWEATHER_API_HOST=
QWEATHER_API_KEY=
QWEATHER_PROJECT_ID=
QWEATHER_KEY_ID=
QWEATHER_PRIVATE_KEY=
QWEATHER_PRIVATE_KEY_FILE=
QWEATHER_JWT_EXPIRE_SECONDS=900

AI_PROVIDER=
AI_API_KEY=
