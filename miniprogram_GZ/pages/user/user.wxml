<view class="page">
  <navigation-bar title="{{copy.title}}" back="{{false}}" color="#193127" background="rgba(244,241,232,0.96)"></navigation-bar>

  <scroll-view class="user-scroll" scroll-y enable-back-to-top refresher-enabled refresher-triggered="{{refreshing}}" bindrefresherrefresh="onUserRefresh">
  <view class="user-content">
  <view class="profile-card">
    <image wx:if="{{user.avatar_url}}" class="avatar image-avatar" src="{{user.avatar_url}}" mode="aspectFill"></image>
    <view wx:else class="avatar">{{copy.defaultAvatar}}</view>
    <view>
      <text class="name">{{user.nickname}}</text>
      <text class="subtitle">{{copy.subtitle}}</text>
    </view>
  </view>

  <view class="profile-form">
    <text class="form-title">{{copy.editProfile}}</text>
    <view class="profile-edit-row">
      <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{profileForm.avatar_url}}" class="form-avatar" src="{{profileForm.avatar_url}}" mode="aspectFill"></image>
        <text wx:else>{{copy.chooseAvatar}}</text>
      </button>
      <input
        class="nickname-input"
        type="nickname"
        value="{{profileForm.nickname}}"
        placeholder="{{copy.nicknamePlaceholder}}"
        bindinput="onNicknameInput"
      />
    </view>
    <view class="save-row"><button class="save-button" loading="{{saving}}" bindtap="onSaveProfile">{{saving ? copy.saving : copy.saveProfile}}</button></view>
  </view>

  <view class="stats-grid">
    <view class="stat">
      <text>{{copy.points}}</text>
      <text class="value">{{user.explore_points}}</text>
    </view>
    <view class="stat">
      <text>{{copy.member}}</text>
      <text class="value small">{{user.is_member ? copy.activeMember : copy.regular}}</text>
    </view>
    <view class="stat">
      <text>{{copy.checkins}}</text>
      <text class="value">{{user.checkin_count || 0}}</text>
    </view>
    <view class="stat">
      <text>{{copy.contributions}}</text>
      <text class="value">{{user.contribution_count || 0}}</text>
    </view>
    <view class="stat">
      <text>{{copy.ecoCredit}}</text>
      <text class="value">{{user.eco_credit || 0}}</text>
    </view>
    <view class="stat">
      <text>{{copy.shares}}</text>
      <text class="value">{{user.share_count || 0}}</text>
    </view>
    <view class="stat">
      <text>{{copy.referrals}}</text>
      <text class="value">{{user.referral_registered_count || 0}}</text>
    </view>
    <view class="stat">
      <text>{{copy.approvedRecommendations}}</text>
      <text class="value">{{user.approved_recommendation_count || 0}}</text>
    </view>
    <view class="stat">
      <text>{{copy.likesReceived}}</text>
      <text class="value">{{user.like_received_count || 0}}</text>
    </view>
    <view class="stat">
      <text>{{copy.likesGiven}}</text>
      <text class="value">{{user.like_given_count || 0}}</text>
    </view>
  </view>

  <view class="panel">
    <view class="row">
      <text>{{copy.accountInfo}}</text>
      <text></text>
    </view>
    <view class="row">
      <text>{{copy.language}}</text>
      <text class="row-value">{{user.language || '-'}}</text>
    </view>
    <view class="row">
      <text>{{copy.safetyLevel}}</text>
      <text class="row-value">{{user.safetyLevelLabel}}</text>
    </view>
    <view class="row">
      <text>{{copy.accountStatus}}</text>
      <text class="row-value">{{user.is_active === false ? copy.inactive : copy.active}}</text>
    </view>
  </view>

  <view class="panel">
    <view class="row">
      <text>{{copy.permissions}}</text>
      <text></text>
    </view>
    <view class="row">
      <text>{{copy.uploadImage}}</text>
      <text>{{user.can_upload_image ? copy.allowed : copy.denied}}</text>
    </view>
    <view class="row">
      <text>{{copy.uploadVideo}}</text>
      <text>{{user.can_upload_video ? copy.allowed : copy.denied}}</text>
    </view>
    <view class="row">
      <text>{{copy.comment}}</text>
      <text>{{user.can_comment ? copy.allowed : copy.denied}}</text>
    </view>
    <view class="row">
      <text>{{copy.checkin}}</text>
      <text>{{user.can_checkin ? copy.allowed : copy.denied}}</text>
    </view>
    <view class="row">
      <text>{{copy.recommend}}</text>
      <text>{{user.can_recommend_spot ? copy.allowed : copy.denied}}</text>
    </view>
    <view class="row">
      <text>{{copy.like}}</text>
      <text>{{user.can_like_comment ? copy.allowed : copy.denied}}</text>
    </view>
    <view class="row">
      <text>{{copy.share}}</text>
      <text>{{user.can_share ? copy.allowed : copy.denied}}</text>
    </view>
  </view>

  <view class="tip">
    <text class="tip-title">{{copy.next}}</text>
    <text>{{copy.tip}}</text>
  </view>
  </view>
  </scroll-view>
  <view class="floating-back" catchtap="onFloatingBackTap">←</view>
</view>
