page {
  height: 100vh;
  background: #f4f1e8;
}

.page {
  height: 100vh;
  background: #f4f1e8;
  display: flex;
  flex-direction: column;
}

.notice {
  margin: 30rpx 24rpx;
  color: #7a7468;
  font-size: 26rpx;
  text-align: center;
}

.detail-scroll {
  flex: 1;
  min-height: 0;
  padding: 18rpx 24rpx calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.locked-notice {
  margin-bottom: 16rpx;
  padding: 15rpx 18rpx;
  border: 1rpx solid #e7dbbc;
  border-radius: 8rpx;
  background: #fff8e8;
  color: #7c6842;
  font-size: 22rpx;
  line-height: 1.45;
}

.hero-swiper,
.photo-empty {
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  border-radius: 8rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.photo-empty {
  background: #edf3ea;
  color: #718176;
  font-size: 24rpx;
  line-height: 360rpx;
  text-align: center;
}

.content-card {
  margin-top: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #e0e6dc;
  border-radius: 8rpx;
  background: #ffffff;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-mark {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex: none;
}

.spot-name {
  color: #193127;
  font-size: 34rpx;
  font-weight: 800;
}

.spot-summary,
.description {
  display: block;
  color: #536357;
  font-size: 25rpx;
  line-height: 1.6;
}

.spot-summary {
  margin-top: 14rpx;
}

.locked-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
  color: #7c6842;
  font-size: 22rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.tag {
  padding: 5rpx 10rpx;
  border-radius: 6rpx;
  background: #edf3ea;
  color: #4d6857;
  font-size: 20rpx;
}

.section-title {
  display: block;
  margin-bottom: 12rpx;
  color: #244334;
  font-size: 26rpx;
  font-weight: 800;
}

.floating-back {
  position: fixed;
  left: 24rpx;
  bottom: calc(236rpx + env(safe-area-inset-bottom));
  z-index: 20;
  width: 76rpx;
  height: 76rpx;
  border: 1rpx solid rgba(47, 107, 79, 0.18);
  border-radius: 50%;
  background: rgba(205, 235, 211, 0.88);
  box-shadow: 0 8rpx 24rpx rgba(25, 49, 39, 0.16);
  color: #2f6b4f;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 76rpx;
  text-align: center;
}
