page, .page { min-height: 100vh; background: #f4f1e8; }
.submit-scroll { height: 100vh; }
.content { padding: 32rpx 24rpx calc(180rpx + env(safe-area-inset-bottom)); }
.notice { margin: 28rpx; padding: 22rpx; border-radius: 8rpx; background: #fff1d3; color: #805d35; font-size: 26rpx; }
.notice.error { background: #ffe5dd; color: #963f2d; }
.spot-head, .section { margin-bottom: 24rpx; padding: 24rpx; border-radius: 8rpx; background: #ffffff; }
.eyebrow, .spot-name, .spot-meta, .media-title, .media-meta, .item-title, .review-note { display: block; }
.eyebrow { color: #4f6a58; font-size: 20rpx; font-weight: 700; }
.spot-name { margin-top: 8rpx; color: #193127; font-size: 40rpx; font-weight: 800; }
.spot-meta { margin-top: 8rpx; color: #667064; font-size: 24rpx; }
.section-head { margin-bottom: 20rpx; color: #203127; font-size: 30rpx; font-weight: 800; display: flex; justify-content: space-between; align-items: center; }
.count, .status { padding: 4rpx 10rpx; border-radius: 6rpx; background: #fff1d3; color: #805d35; font-size: 20rpx; }
.location-chip { height: 70rpx; margin-bottom: 16rpx; padding: 0 18rpx; border-radius: 8rpx; background: #fff1d3; color: #805d35; line-height: 70rpx; font-size: 24rpx; }
.location-chip.active { background: #e7f3e8; color: #2f6b4f; }
.media-button, .submit-button { height: 72rpx; margin: 0 0 16rpx; border-radius: 8rpx; background: #355c72; color: #fff; font-size: 25rpx; line-height: 72rpx; }
.submit-button { margin-top: 16rpx; background: #1f5f45; }
.media-state { padding: 14rpx; border-radius: 8rpx; background: #f4f1e8; display: flex; align-items: center; gap: 14rpx; }
.media-preview { width: 112rpx; height: 112rpx; border-radius: 8rpx; background: #e4e0d3; flex: none; }
.media-info { flex: 1; min-width: 0; }
.media-title { color: #203127; font-size: 26rpx; font-weight: 800; }
.media-meta, .review-note { margin-top: 6rpx; color: #667064; font-size: 22rpx; }
.remove-media { padding: 8rpx; color: #9a5145; font-size: 22rpx; }
.form-input, .form-textarea { width: 100%; margin-bottom: 16rpx; padding: 18rpx; border-radius: 8rpx; background: #f4f1e8; color: #203127; font-size: 26rpx; box-sizing: border-box; }
.form-input { height: 76rpx; }
.form-textarea { height: 210rpx; }
.checkin-item { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #ece7dc; }
.content-image, .content-video { width: 100%; height: 330rpx; margin-bottom: 14rpx; border-radius: 8rpx; background: #e4e0d3; }
.item-head { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.item-title { flex: 1; color: #203127; font-size: 27rpx; font-weight: 800; }
.floating-back { position: fixed; left: 24rpx; bottom: calc(140rpx + env(safe-area-inset-bottom)); z-index: 20; width: 76rpx; height: 76rpx; border-radius: 50%; background: rgba(205, 235, 211, 0.88); color: #2f6b4f; border: 1rpx solid rgba(47, 107, 79, 0.18); font-size: 40rpx; font-weight: 700; line-height: 76rpx; text-align: center; box-shadow: 0 8rpx 24rpx rgba(25, 49, 39, 0.16); }
