<view class="page">
  <navigation-bar title="{{copy.title}}" back="{{false}}" color="#193127" background="rgba(244,241,232,0.96)"></navigation-bar>

  <view class="hero">
    <text class="eyebrow">DATABASE ASSISTANT</text>
    <text class="headline">{{copy.headline}}</text>
    <text class="subtitle">{{copy.subtitle}}</text>
  </view>

  <scroll-view class="chat-scroll" scroll-y scroll-into-view="{{messageAnchor}}" enable-back-to-top>
    <view class="chat-card">
      <view wx:for="{{messages}}" wx:key="id" id="{{item.id}}" class="message-row {{item.role}}">
        <view class="bubble {{item.role}}">
          <text class="message-text">{{item.content}}</text>
          <view wx:if="{{item.actions.length}}" class="action-row">
            <button wx:for="{{item.actions}}" wx:for-item="action" wx:key="spot_id" class="assistant-action" data-action="{{action}}" catchtap="onAssistantAction">{{action.label}}</button>
          </view>
          <view wx:if="{{item.suggestions.length}}" class="suggestion-row">
            <view wx:for="{{item.suggestions}}" wx:for-item="spot" wx:key="id" class="suggestion" data-name="{{spot.name}}" catchtap="onSuggestionTap">{{spot.name}}</view>
          </view>
        </view>
      </view>
      <view wx:if="{{thinking}}" class="message-row assistant" id="{{messageAnchor}}">
        <view class="bubble assistant thinking">{{copy.thinking}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="composer">
    <input
      value="{{inputValue}}"
      placeholder="{{copy.input}}"
      confirm-type="send"
      bindinput="onInputChange"
      bindconfirm="onSendTap"
    />
    <button loading="{{thinking}}" bindtap="onSendTap">{{copy.send}}</button>
  </view>
  <view class="floating-back" catchtap="onFloatingBackTap">←</view>
</view>
