page {
  height: 100vh;
  background: #f4f1e8;
  overflow: hidden;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f4f1e8;
  box-sizing: border-box;
}

.hero {
  margin: 18rpx 24rpx 0;
  padding: 26rpx 28rpx;
  border-radius: 8rpx;
  background: #193127;
  color: #ffffff;
  flex: none;
}

.eyebrow,
.headline,
.subtitle,
.message-text {
  display: block;
}

.eyebrow {
  color: #a8c8b4;
  font-size: 20rpx;
  font-weight: 700;
}

.headline {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.subtitle {
  margin-top: 10rpx;
  color: #d8e4dc;
  font-size: 24rpx;
  line-height: 1.5;
}

.chat-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
}

.chat-card {
  min-height: 100%;
  padding: 0 24rpx calc(156rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.message-row {
  display: flex;
  margin-bottom: 16rpx;
}

.message-row.user {
  justify-content: flex-end;
}

.bubble {
  max-width: 580rpx;
  padding: 20rpx 22rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 1.55;
  box-sizing: border-box;
}

.bubble.assistant {
  background: #ffffff;
  color: #263b2f;
  border: 1rpx solid #e0e6dc;
}

.bubble.user {
  background: #dceef5;
  color: #1f4a5c;
}

.thinking {
  color: #698071;
}

.action-row,
.suggestion-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.assistant-action,
.suggestion {
  min-height: 52rpx;
  padding: 0 16rpx;
  border-radius: 7rpx;
  background: #e5f1e7;
  color: #1f5f45;
  font-size: 22rpx;
  line-height: 52rpx;
  box-sizing: border-box;
}

.composer {
  padding: 14rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e0e6dc;
  background: #f8f6ef;
  display: flex;
  gap: 14rpx;
  flex: none;
  box-sizing: border-box;
}

.composer input {
  min-width: 0;
  flex: 1;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #203127;
  font-size: 24rpx;
  box-sizing: border-box;
}

.composer button {
  width: 122rpx;
  height: 76rpx;
  border-radius: 8rpx;
  background: #1f5f45;
  color: #ffffff;
  font-size: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.floating-back {
  position: fixed;
  left: 24rpx;
  bottom: calc(128rpx + env(safe-area-inset-bottom));
  z-index: 20;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(205, 235, 211, 0.88);
  color: #2f6b4f;
  border: 1rpx solid rgba(47, 107, 79, 0.18);
  font-size: 40rpx;
  font-weight: 700;
  line-height: 76rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(25, 49, 39, 0.16);
}
