page {
  height: 100vh;
  background: #f4f1e8;
}

.page {
  height: 100vh;
  background: #f4f1e8;
  display: flex;
  flex-direction: column;
}

.filter-context {
  margin: 18rpx 24rpx 14rpx;
  padding: 20rpx;
  border: 1rpx solid #dce8dc;
  border-radius: 8rpx;
  background: #ffffff;
}

.context-title,
.context-body {
  display: block;
}

.list-filter-controls {
  margin-top: 18rpx;
}

.keyword-input {
  width: 100%;
  height: 64rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border: 1rpx solid #d8e2d7;
  border-radius: 6rpx;
  background: #fbfdf9;
  color: #203e2e;
  font-size: 24rpx;
}

.filter-select-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.filter-picker {
  flex: 1;
  min-width: 0;
}

.filter-picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60rpx;
  padding: 0 14rpx;
  border: 1rpx solid #d8e2d7;
  border-radius: 6rpx;
  color: #55705d;
  font-size: 22rpx;
  background: #fbfdf9;
}

.picker-value {
  max-width: 68%;
  color: #203e2e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.context-title {
  color: #54705d;
  font-size: 22rpx;
}

.context-body {
  margin-top: 8rpx;
  color: #203e2e;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.45;
}

.notice {
  margin: 30rpx 24rpx;
  color: #7a7468;
  font-size: 26rpx;
  text-align: center;
}

.spot-list {
  flex: 1;
  min-height: 0;
  padding: 0 24rpx calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.spot-card {
  margin-bottom: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #e0e6dc;
  border-radius: 8rpx;
  background: #ffffff;
}

.spot-card-layout {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
}

.spot-card-main {
  flex: 1;
  min-width: 0;
}

.spot-cover-wrap {
  position: relative;
  border-radius: 6rpx;
  overflow: hidden;
  background: #e7ece5;
}

.card-cover-right {
  flex: none;
  width: 196rpx;
  height: 196rpx;
}

.spot-cover {
  display: block;
  width: 100%;
  height: 100%;
}

.spot-cover-state {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: #5f7568;
  font-size: 22rpx;
  background: rgba(231, 236, 229, 0.92);
}

.spot-cover-error {
  color: #8a6655;
}

.cover-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #cbd8cc;
  border-top-color: #2f6b4f;
  border-radius: 50%;
  animation: cover-spin 0.8s linear infinite;
}

@keyframes cover-spin {
  to { transform: rotate(360deg); }
}


.card-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.marker {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex: none;
}

.spot-name {
  flex: 1;
  min-width: 0;
  color: #193127;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.spot-level {
  flex: none;
  color: #47705a;
  font-size: 23rpx;
  font-weight: 700;
}

.spot-summary {
  display: -webkit-box;
  margin-top: 12rpx;
  color: #536357;
  font-size: 24rpx;
  line-height: 1.5;
  overflow: hidden;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.spot-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 14rpx;
  color: #798178;
  font-size: 22rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.tag {
  padding: 5rpx 10rpx;
  border-radius: 6rpx;
  background: #edf3ea;
  color: #4d6857;
  font-size: 20rpx;
}

.floating-back {
  position: fixed;
  left: 24rpx;
  bottom: calc(236rpx + env(safe-area-inset-bottom));
  z-index: 20;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(205, 235, 211, 0.88);
  color: #2f6b4f;
  border: 1rpx solid rgba(47, 107, 79, 0.18);
  font-size: 40rpx;
  font-weight: 700;
  line-height: 76rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(25, 49, 39, 0.16);
}
