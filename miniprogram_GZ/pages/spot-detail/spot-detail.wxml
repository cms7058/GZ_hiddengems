<view class="page">
  <navigation-bar title="{{copy.navTitle}}" back="{{true}}" color="#193127" background="rgba(244,241,232,0.96)"></navigation-bar>

  <scroll-view class="detail-scroll" scroll-y scroll-with-animation scroll-into-view="{{scrollTarget}}" refresher-enabled refresher-triggered="{{refreshing}}" bindrefresherrefresh="onPullDownRefresh">
    <view wx:if="{{loading}}" class="notice">{{copy.loading}}</view>
    <view wx:elif="{{error}}" class="notice error">{{copy.loadFailed}}</view>

    <block wx:elif="{{spot}}">
      <view class="hero">
        <swiper wx:if="{{photoSlides.length}}" class="hero-media" indicator-dots circular autoplay interval="4500">
          <swiper-item wx:for="{{photoSlides}}" wx:for-item="photo" wx:key="id">
            <video
              wx:if="{{photo.media_type === 'video'}}"
              class="hero-image-thumb hero-video-thumb"
              src="{{photo.display_url || photo.image_url}}"
              object-fit="cover"
              controls
            ></video>
            <image
              wx:else
              class="hero-image-thumb"
              src="{{photo.display_url || photo.image_url}}"
              mode="aspectFill"
              data-url="{{photo.display_url || photo.image_url}}"
              data-media-type="{{photo.media_type || 'image'}}"
              bindtap="onPreviewSpotPhoto"
            ></image>
          </swiper-item>
        </swiper>
        <map
          wx:else
          id="spotDetailMap"
          class="map"
          latitude="{{spot.latitude}}"
          longitude="{{spot.longitude}}"
          scale="10"
          markers="{{markers}}"
          show-location="{{hasUserLocation}}"
        ></map>
        <!-- The gallery replaces the visible map, but MapContext still needs a rendered map to open a third-party map app. -->
        <map
          wx:if="{{photoSlides.length}}"
          id="spotDetailMap"
          class="navigation-map"
          latitude="{{spot.latitude}}"
          longitude="{{spot.longitude}}"
          markers="{{markers}}"
          show-location="{{hasUserLocation}}"
        ></map>
      </view>

      <view class="content">
        <view class="title-row">
          <view class="title-block">
            <text class="eyebrow">AI EXPLORER</text>
            <text class="title">{{spot.name}}</text>
            <text class="summary">{{spot.summary}}</text>
          </view>
          <view class="level">Lv.{{spot.recommendation_level}}</view>
        </view>

        <view wx:if="{{!spot.is_unlocked}}" class="locked-banner">{{copy.locked}}</view>
        <view wx:if="{{fallbackMode}}" class="locked-banner">{{copy.fallbackNotice}}</view>

        <view class="stats">
          <view class="stat stat-action" data-target="checkin" bindtap="onStatTap">
            <text class="stat-number">{{spot.user_explore_points}}</text>
            <text>{{copy.points}}</text>
          </view>
          <view class="stat stat-action" data-target="description" bindtap="onStatTap">
            <text class="stat-number">{{spot.required_explore_points}}</text>
            <text>{{copy.unlockNeed}}</text>
          </view>
          <view class="stat stat-action" data-target="interaction" bindtap="onStatTap">
            <text class="stat-number">{{userCount}}</text>
            <text>{{copy.users}}</text>
          </view>
          <view class="stat stat-action" data-target="community" bindtap="onStatTap">
            <text class="stat-number">{{spot.travel_notes.length + spot.comments.length}}</text>
            <text>{{copy.notes}}/{{copy.comments}}</text>
          </view>
        </view>

        <view id="description" class="section">
          <view class="section-head">
            <text>{{copy.description}}</text>
          </view>
          <text class="body-text">{{spot.description || spot.summary}}</text>
          <view class="meta-grid">
            <view>
              <text class="meta-label">{{copy.location}}</text>
              <text class="meta-value">{{spot.city}} / {{spot.county}}</text>
            </view>
            <view>
              <text class="meta-label">{{copy.tags}}</text>
              <view class="tag-row">
                <text wx:for="{{spot.tags}}" wx:key="id" class="tag">{{item.name}}</text>
              </view>
            </view>
          </view>
          <view class="explore-actions">
            <view wx:if="{{user.can_checkin}}" class="explore-action" data-action="checkin" bindtap="onActionTap">
              <text class="explore-action-title">{{copy.checkin}}</text>
              <text class="explore-action-arrow">›</text>
            </view>
            <view wx:if="{{user.can_comment && spot.has_successful_checkin}}" class="explore-action" data-action="note" bindtap="onActionTap">
              <text class="explore-action-title">{{copy.writeNote}}</text>
              <text class="explore-action-arrow">›</text>
            </view>
            <view wx:if="{{user.can_comment && spot.has_successful_checkin}}" class="explore-action" data-action="comment" bindtap="onActionTap">
              <text class="explore-action-title">{{copy.leaveComment}}</text>
              <text class="explore-action-arrow">›</text>
            </view>
          </view>
          <text wx:if="{{user.can_comment && !spot.has_successful_checkin}}" class="explore-action-hint">{{copy.checkinRequired}}</text>
        </view>

        <view class="section safety-section">
          <view class="section-head">
            <text>{{copy.safety}}</text>
            <text wx:if="{{safety}}" class="count">{{safety.source}}</text>
          </view>
          <view wx:if="{{!safety}}" class="empty">{{copy.safetyNotConfigured}}</view>
          <block wx:else>
            <view class="safety-card">
              <text class="safety-label">{{copy.weather}}</text>
              <text class="safety-title">{{safety.weatherText}}</text>
              <text class="safety-meta">{{safety.weatherMeta}}</text>
            </view>
            <view class="safety-card">
              <text class="safety-label">{{copy.riverRisk}}</text>
              <text class="safety-title">{{safety.riverLevelText}}</text>
              <text class="safety-meta">{{safety.river_warning.summary}}</text>
            </view>
            <view wx:if="{{safety.upstreamWeatherText}}" class="safety-card">
              <text class="safety-label">{{copy.upstreamWeather}}</text>
              <text class="safety-title">{{safety.upstreamWeatherText}}</text>
              <text class="safety-meta">{{safety.upstreamWeatherMeta}}</text>
            </view>
            <view class="safety-card">
              <text class="safety-label">{{copy.upstreamAlerts}}</text>
              <text wx:if="{{safety.upstreamAlerts.length === 0}}" class="safety-meta">{{copy.noUpstreamAlerts}}</text>
              <view wx:for="{{safety.upstreamAlerts}}" wx:key="id" class="alert-item">
                <text class="safety-title">{{item.headline}}</text>
                <text class="safety-meta">{{item.description}}</text>
              </view>
            </view>
            <view class="safety-card">
              <text class="safety-label">{{copy.alerts}}</text>
              <text wx:if="{{safety.alerts.length === 0}}" class="safety-meta">{{copy.noAlerts}}</text>
              <view wx:for="{{safety.alerts}}" wx:key="id" class="alert-item">
                <text class="safety-title">{{item.headline}}</text>
                <text class="safety-meta">{{item.description}}</text>
              </view>
            </view>
          </block>
        </view>

        <view id="community">
          <view class="section">
            <view class="section-head">
              <text>{{copy.notes}}</text>
              <text class="count">{{spot.travel_notes.length}}</text>
            </view>
            <view wx:if="{{spot.travel_notes.length === 0}}" class="empty">{{copy.emptyNotes}}</view>
            <view wx:for="{{spot.travel_notes}}" wx:for-item="note" wx:key="id" class="note-item">
              <scroll-view wx:if="{{note.media.length}}" class="note-media-scroll" scroll-x show-scrollbar="{{false}}">
                <view class="note-media-row">
                  <block wx:for="{{note.media}}" wx:key="id">
                    <image wx:if="{{item.media_type === 'image'}}" class="note-media-image" src="{{item.display_url || item.media_url}}" mode="heightFix" data-note-id="{{note.id}}" data-url="{{item.display_url || item.media_url}}" bindtap="onPreviewTravelNoteImage"></image>
                    <video wx:else class="note-media-video" src="{{item.display_url || item.media_url}}" object-fit="contain" controls></video>
                  </block>
                </view>
              </scroll-view>
              <image wx:elif="{{note.display_url || note.image_url}}" class="note-media-image note-media-image-single" src="{{note.display_url || note.image_url}}" mode="heightFix" data-note-id="{{note.id}}" data-url="{{note.display_url || note.image_url}}" bindtap="onPreviewTravelNoteImage"></image>
              <view class="note-head">
                <text class="note-title">{{note.title}}</text>
                <text wx:if="{{note.is_featured}}" class="featured">{{copy.featured}}</text>
                <text wx:if="{{note.statusText}}" class="review-status">{{note.statusText}}</text>
              </view>
              <text class="author">{{note.nickname}}</text>
              <text class="body-text">{{note.content}}</text>
            </view>
          </view>

          <view class="section">
            <view class="section-head">
              <text>{{copy.comments}}</text>
              <text class="count">{{spot.comments.length}}</text>
            </view>
            <view wx:if="{{spot.comments.length === 0}}" class="empty">{{copy.emptyComments}}</view>
            <view wx:for="{{spot.comments}}" wx:key="id" class="comment-item">
              <image wx:if="{{item.display_url || item.image_url}}" class="content-image" src="{{item.display_url || item.image_url}}" mode="aspectFill"></image>
              <text class="author">{{item.nickname}}</text>
              <text wx:if="{{item.statusText}}" class="review-status">{{item.statusText}}</text>
              <text class="body-text">{{item.content}}</text>
              <view wx:if="{{!item.isMine}}" class="comment-like" data-id="{{item.id}}" bindtap="onToggleCommentLike">
                <text>{{item.liked_by_me ? copy.unlike : copy.like}}</text>
                <text wx:if="{{item.like_count}}"> {{item.like_count}}</text>
              </view>
            </view>
          </view>
        </view>

        <view id="interaction" class="section">
          <view class="section-head">
            <text>{{copy.interaction}}</text>
            <text class="count">{{interactionMessages.length}}</text>
          </view>
          <text class="body-text">{{copy.interactionDescription}}</text>
          <view wx:if="{{interactionMessages.length === 0}}" class="empty">{{copy.emptyInteraction}}</view>
          <view wx:else class="interaction-message-list">
            <view wx:for="{{interactionMessages}}" wx:key="id" class="interaction-message">
              <text class="interaction-message-name">{{item.nickname}}：</text>
              <text class="interaction-message-content">{{item.content}}</text>
            </view>
          </view>
          <button wx:if="{{user.can_comment && spot.has_successful_checkin}}" class="interaction-button" bindtap="onStartInteraction">{{copy.startInteraction}}</button>
          <text wx:if="{{user.can_comment && !spot.has_successful_checkin}}" class="action-hint">{{copy.checkinRequired}}</text>
        </view>

        <view class="section">
          <view class="section-head">
            <text>{{copy.recommendations}}</text>
            <text class="count">{{spot.lifestyle_recommendations.length}}</text>
          </view>
          <view wx:if="{{groupedRecommendations.length === 0}}" class="empty">{{copy.emptyRecommendations}}</view>
          <view wx:for="{{groupedRecommendations}}" wx:key="category" class="rec-group">
            <text class="rec-category">{{item.label}}</text>
            <view wx:for="{{item.items}}" wx:for-item="rec" wx:key="id" class="rec-item">
              <image wx:if="{{rec.display_url || rec.image_url}}" class="rec-image" src="{{rec.display_url || rec.image_url}}" mode="aspectFill"></image>
              <view class="rec-body">
                <text class="rec-title">{{rec.displayName}}</text>
                <text class="rec-summary">{{rec.displaySummary}}</text>
                <text wx:if="{{rec.address}}" class="rec-meta">{{copy.address}}：{{rec.address}}</text>
                <text wx:if="{{rec.contact}}" class="rec-meta">{{copy.contact}}：{{rec.contact}}</text>
              </view>
            </view>
          </view>
        </view>

      </view>
    </block>
  </scroll-view>
  <canvas canvas-id="detailMarkerCanvas" class="marker-canvas" style="width: 40px; height: 50px;"></canvas>
  <canvas canvas-id="travelNoteWatermarkCanvas" class="watermark-canvas" width="{{watermarkCanvasWidth}}" height="{{watermarkCanvasHeight}}" style="width: {{watermarkCanvasWidth}}px; height: {{watermarkCanvasHeight}}px;"></canvas>
  <view wx:if="{{spot}}" class="floating-back" catchtap="onFloatingBackTap">←</view>
  <view wx:if="{{spot}}" class="floating-navigate" catchtap="onNavigateTap">{{copy.goThere}}</view>
  <bottom-tabs lang="{{lang}}"></bottom-tabs>
</view>
