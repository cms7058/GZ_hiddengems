page {
  height: 100vh;
  background: #f4f1e8;
}

.page {
  min-height: 100vh;
  background: #f4f1e8;
}

.nav-action {
  min-width: 72rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 28rpx;
  background: #193127;
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-scroll {
  height: 100vh;
}

.hero {
  height: 520rpx;
  background: #dbe4d6;
}

.map {
  width: 100%;
  height: 100%;
}

.marker-canvas {
  /* Native map on some phones skips a canvas that is positioned off-screen. */
  position: absolute;
  left: 0;
  top: 0;
  width: 40px;
  height: 50px;
  opacity: 0.01;
  pointer-events: none;
  z-index: 0;
}

.watermark-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  opacity: 0;
  pointer-events: none;
}

.hero-media,
.hero-image {
  width: 100%;
  height: 100%;
}

.hero-image-thumb {
  width: 100%;
  height: 100%;
  background: #24372d;
}

.hero-video-thumb {
  display: block;
}

.video-channel-list { margin-top: 24rpx; }

.video-channel-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 88rpx;
  padding: 18rpx 22rpx;
  border-radius: 8rpx;
  background: #193127;
  color: #ffffff;
}

.video-channel-link + .video-channel-link { margin-top: 12rpx; }

.video-channel-link-title { font-size: 28rpx; font-weight: 800; }
.video-channel-link-action { color: #cfe5d4; font-size: 24rpx; }

.content {
  margin-top: -24rpx;
  padding: 28rpx 24rpx calc(148rpx + env(safe-area-inset-bottom));
  border-radius: 8rpx 8rpx 0 0;
  background: #f8f6ef;
  position: relative;
  z-index: 2;
}

.action-hint {
  display: block;
  width: 100%;
  color: #7a8179;
  font-size: 22rpx;
  line-height: 1.5;
}

.note-media-scroll {
  width: 100%;
  height: 280rpx;
  margin-bottom: 14rpx;
}

.note-media-row {
  display: inline-flex;
  min-height: 280rpx;
  gap: 12rpx;
  align-items: center;
}

.note-media-image,
.note-media-video {
  display: block;
  flex: none;
  height: 280rpx;
  width: auto;
  border-radius: 8rpx;
  background: #e4e0d3;
}

.note-media-video {
  width: 420rpx;
}

.note-media-image-single {
  margin-bottom: 14rpx;
}

.title-row {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.title-block {
  flex: 1;
  min-width: 0;
}

.eyebrow,
.title,
.summary,
.body-text,
.meta-label,
.meta-value,
.rec-category,
.rec-title,
.rec-summary,
.rec-meta,
.note-title,
.author {
  display: block;
}

.eyebrow {
  color: #4f6a58;
  font-size: 20rpx;
  font-weight: 700;
}

.title {
  margin-top: 8rpx;
  color: #193127;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.summary {
  margin-top: 14rpx;
  color: #526357;
  font-size: 26rpx;
  line-height: 1.5;
}

.level {
  flex: none;
  min-width: 92rpx;
  height: 64rpx;
  border-radius: 8rpx;
  background: #1f5f45;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.floating-navigate {
  position: fixed;
  right: 24rpx;
  bottom: calc(236rpx + env(safe-area-inset-bottom));
  z-index: 20;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: rgba(123, 194, 232, 0.7);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  line-height: 1.15;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(40, 111, 150, 0.2);
}

.navigation-map {
  position: fixed;
  top: -1000px;
  left: -1000px;
  width: 2px;
  height: 2px;
  opacity: 0;
  pointer-events: none;
}

.floating-back {
  position: fixed;
  left: 24rpx;
  bottom: calc(236rpx + env(safe-area-inset-bottom));
  z-index: 20;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(205, 235, 211, 0.88);
  color: #2f6b4f;
  border: 1rpx solid rgba(47, 107, 79, 0.18);
  font-size: 40rpx;
  font-weight: 700;
  line-height: 76rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(25, 49, 39, 0.16);
}

.locked-banner,
.notice {
  margin: 24rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #fff1d3;
  color: #805d35;
  font-size: 26rpx;
}

.notice.error {
  background: #ffe5dd;
  color: #963f2d;
}

.stats {
  margin-top: 26rpx;
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.stat {
  width: 0;
  flex: 1;
  min-width: 0;
  min-height: 112rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #667064;
  font-size: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  white-space: nowrap;
}

.stat-number {
  color: #193127;
  font-size: 34rpx;
  font-weight: 800;
}

.stat-action {
  border: 1rpx solid transparent;
}

.stat-action:active {
  border-color: #7bc2e8;
  background: #eef8fc;
}

.section {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.section-head {
  margin-bottom: 18rpx;
  color: #203127;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.count {
  min-width: 42rpx;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 17rpx;
  background: #eef2e8;
  color: #496251;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.body-text {
  color: #4f5e53;
  font-size: 26rpx;
  line-height: 1.58;
}

.meta-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.meta-label {
  color: #7d8179;
  font-size: 22rpx;
}

.meta-value {
  margin-top: 6rpx;
  color: #203127;
  font-size: 25rpx;
}

.tag-row {
  margin-top: 8rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  background: #eef2e8;
  color: #496251;
  font-size: 20rpx;
}

.explore-actions {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #ece7dc;
  display: flex;
  gap: 12rpx;
}

.explore-action {
  flex: 1;
  min-width: 0;
  min-height: 64rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #e7f3e8;
  color: #2f6b4f;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.explore-action-hint {
  display: block;
  margin-top: 12rpx;
  color: #7a8179;
  font-size: 22rpx;
  line-height: 1.5;
}

.explore-action:active {
  background: #d5ead8;
}

.explore-action-title {
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.explore-action-arrow {
  margin-left: 6rpx;
  font-size: 34rpx;
  line-height: 1;
}

.empty {
  padding: 18rpx 0;
  color: #8b867c;
  font-size: 24rpx;
}

.rec-group {
  margin-top: 18rpx;
}

.rec-category {
  margin-bottom: 12rpx;
  color: #2f6b4f;
  font-size: 24rpx;
  font-weight: 800;
}

.rec-item {
  margin-bottom: 16rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f8f6ef;
  display: flex;
  gap: 16rpx;
}

.rec-image {
  width: 144rpx;
  height: 144rpx;
  border-radius: 8rpx;
  background: #e4e0d3;
  flex: none;
}

.rec-body {
  flex: 1;
  min-width: 0;
}

.rec-title {
  color: #203127;
  font-size: 27rpx;
  font-weight: 800;
}

.rec-summary,
.rec-meta {
  margin-top: 8rpx;
  color: #5d6a60;
  font-size: 23rpx;
  line-height: 1.45;
}

.note-item,
.comment-item {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ece7dc;
}

.comment-like {
  width: fit-content;
  margin-top: 12rpx;
  padding: 6rpx 12rpx;
  border: 1rpx solid #b8d2c0;
  border-radius: 6rpx;
  color: #2a6c4e;
  font-size: 22rpx;
}

.my-checkins {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #ece7dc;
}

.checkin-item {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f4f1e8;
}

.checkin-video {
  width: 100%;
  height: 360rpx;
  margin-bottom: 14rpx;
  border-radius: 8rpx;
  background: #e4e0d3;
}

.review-status {
  flex: none;
  margin-left: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: #fff1d3;
  color: #805d35;
  font-size: 20rpx;
}

.review-note {
  display: block;
  margin-top: 10rpx;
  color: #6b746a;
  font-size: 22rpx;
  line-height: 1.45;
}

.interaction-message-list {
  margin-top: 18rpx;
}

.interaction-message {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f4f1e8;
  color: #4f5e53;
  font-size: 25rpx;
  line-height: 1.55;
}

.interaction-message-name {
  color: #2f6b4f;
  font-weight: 800;
}

.interaction-message-content {
  color: #4f5e53;
}

.interaction-button {
  height: 64rpx;
  margin: 20rpx 0 0;
  border-radius: 8rpx;
  background: #355c72;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 64rpx;
}

.note-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.note-title {
  color: #203127;
  font-size: 28rpx;
  font-weight: 800;
}

.featured {
  flex: none;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: #fff1d3;
  color: #805d35;
  font-size: 20rpx;
}

.author {
  margin: 8rpx 0;
  color: #7a8179;
  font-size: 22rpx;
}

.content-image {
  width: 100%;
  height: 280rpx;
  margin-bottom: 14rpx;
  border-radius: 8rpx;
  background: #e4e0d3;
}

.action-section {
  background: #fffdf8;
}

.safety-section {
  background: #fffdf8;
}

.safety-card {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f4f1e8;
}

.safety-label,
.safety-title,
.safety-meta {
  display: block;
}

.safety-label {
  color: #7a8179;
  font-size: 22rpx;
}

.safety-title {
  margin-top: 8rpx;
  color: #203127;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
}

.safety-meta {
  margin-top: 8rpx;
  color: #5d6a60;
  font-size: 23rpx;
  line-height: 1.5;
}

.alert-item {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #e3ded2;
}

.action-block {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #ece7dc;
}

.checkin-toolbar {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.location-chip {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: #fff1d3;
  color: #805d35;
  font-size: 23rpx;
  line-height: 64rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.location-chip.active {
  background: #e7f3e8;
  color: #2f6b4f;
}

.media-button {
  flex: none;
  width: 210rpx;
  height: 64rpx;
  padding: 0;
  border-radius: 8rpx;
  background: #355c72;
  color: #ffffff;
  font-size: 23rpx;
  line-height: 64rpx;
}

.media-state {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 8rpx;
  background: #f4f1e8;
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.media-preview {
  width: 112rpx;
  height: 112rpx;
  border-radius: 8rpx;
  background: #e4e0d3;
  flex: none;
}

.media-video {
  display: block;
}

.media-info {
  flex: 1;
  min-width: 0;
}

.media-title,
.media-meta {
  display: block;
}

.media-title {
  color: #203127;
  font-size: 26rpx;
  font-weight: 800;
}

.media-meta {
  margin-top: 6rpx;
  color: #667064;
  font-size: 22rpx;
}

.action-block.last {
  border-bottom: 0;
  padding-bottom: 0;
}

.form-input,
.form-textarea {
  width: 100%;
  border-radius: 8rpx;
  background: #f4f1e8;
  color: #203127;
  font-size: 26rpx;
  box-sizing: border-box;
}

.form-input {
  height: 78rpx;
  padding: 0 20rpx;
}

.form-textarea {
  min-height: 156rpx;
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  line-height: 1.5;
}

.action-block .form-textarea:first-child {
  margin-top: 0;
}

.action-button {
  height: 78rpx;
  margin-top: 16rpx;
  border-radius: 8rpx;
  background: #1f5f45;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.secondary-action {
  background: #2f6b4f;
}
