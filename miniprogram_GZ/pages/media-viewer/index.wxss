page {
  height: 100vh;
  background: #17261f;
}

.page {
  height: 100vh;
  background: #17261f;
  display: flex;
  flex-direction: column;
}

.image-swiper,
.viewer-video {
  flex: 1;
  width: 100%;
  min-height: 0;
}

.viewer-image {
  width: 100%;
  height: 100%;
}

.floating-back {
  position: fixed;
  left: 24rpx;
  bottom: calc(52rpx + env(safe-area-inset-bottom));
  z-index: 20;
  width: 76rpx;
  height: 76rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  background: rgba(205, 235, 211, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.24);
  color: #2f6b4f;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 76rpx;
  text-align: center;
}
