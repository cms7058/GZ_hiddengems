<view class="page">
  <navigation-bar title="{{copy.navTitle}}" back="{{false}}" color="#193127" background="rgba(244,241,232,0.96)"></navigation-bar>

  <view class="hero">
    <map
      id="gemsMap"
      class="map"
      latitude="{{center.latitude}}"
      longitude="{{center.longitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      bindmarkertap="onMarkerTap"
      bindregionchange="onMapRegionChange"
      show-location="{{hasUserLocation}}"
    ></map>
    <canvas canvas-id="homeMarkerCanvas" class="marker-canvas" width="40" height="50" style="width: 40px; height: 50px;"></canvas>

    <view class="map-controls">
      <view class="map-control" catchtap="onZoomIn">+</view>
      <view class="map-control" catchtap="onZoomOut">-</view>
      <view class="map-control text" catchtap="onResetMap">{{copy.resetMap}}</view>
    </view>
  </view>

  <view class="sheet">
    <view class="tag-row">
      <view class="tag {{allTagsSelected ? 'active' : ''}}" catchtouchstart="onClearTags">{{copy.allTags}}</view>
      <view
        wx:for="{{tags}}"
        wx:key="id"
        class="tag {{item.active ? 'active' : ''}}"
        data-id="{{item.id}}"
        catchtouchstart="onTagTap"
      >
        {{item.name}}
      </view>
      <view class="tag recommend-tag" catchtap="onRecommendSpot">{{copy.recommendSpot}}</view>
    </view>

    <view wx:if="{{serviceClosed}}" class="notice">{{copy.serviceClosed}}</view>
    <view wx:elif="{{offline}}" class="notice">{{copy.offline}}<text wx:if="{{offlineDetail}}">（{{offlineDetail}}）</text></view>
    <view wx:elif="{{loading}}" class="notice">{{copy.loading}}</view>
    <view class="level-section">
      <view class="section-title-row">
        <text class="section-title">{{copy.levelOverview}}</text>
        <text class="section-subtitle">{{copy.allLevels}}</text>
      </view>
      <view class="level-row">
        <view class="level-filter {{allLevelsSelected ? 'active' : ''}}" catchtouchstart="onClearLevels">
          <text>{{copy.allLevels}}</text>
        </view>
        <view
          wx:for="{{levelOptions}}"
          wx:key="level"
          class="level-filter {{item.active ? 'active' : ''}}"
          data-level="{{item.level}}"
          catchtouchstart="onLevelTap"
        >
          <view class="level-color" style="background: {{item.markerColor}};"></view>
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="filter-summary">
      <view class="summary-copy">
        <text class="summary-main">{{copy.filterSummaryPrefix}} {{filterSummary.tags}} · {{filterSummary.levels}}</text>
        <text class="summary-count">{{copy.filterSummaryCountPrefix}}{{filterSummary.count}}{{copy.filterSummaryCountSuffix}}</text>
      </view>
      <view class="nearby-search">
        <text class="nearby-label">{{copy.radius}}</text>
        <view class="radius-control">
          <input class="radius-input" type="digit" value="{{nearbyRadiusKm}}" maxlength="4" bindfocus="onNearbyInputFocus" bindblur="onNearbyInputBlur" bindconfirm="onNearbyInputConfirm" bindinput="onNearbyRadiusInput" />
          <text class="radius-unit">{{copy.radiusUnit}}</text>
        </view>
      </view>
      <view class="summary-chips">
        <view class="spot-chip locked" catchtap="onOpenLockedList">
          <text>{{copy.locked}} {{filterSummary.lockedCount}}</text>
        </view>
        <view class="spot-chip unlocked" catchtap="onOpenUnlockedList">
          <text>{{copy.unlocked}} {{filterSummary.unlockedCount}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{!loading && filteredSpots.length === 0}}" class="empty-filter">{{copy.noEligibleSpots}}</view>
  </view>

  <view wx:if="{{showProfileAuth}}" class="agreement-mask">
    <view class="agreement-panel">
      <text class="agreement-title">{{copy.profileTitle}}</text>
      <text class="agreement-body">{{copy.profileBody}}</text>
      <button class="agreement-button" loading="{{profileLoading}}" bindtap="onAuthorizeProfile">{{copy.profileButton}}</button>
      <button class="agreement-button secondary" bindtap="onSkipProfileAuth">{{copy.profileSkip}}</button>
    </view>
  </view>

  <view wx:if="{{showSafetyAgreement}}" class="agreement-mask">
    <view class="agreement-panel">
      <text class="agreement-title">安全协议</text>
      <text class="agreement-body">
        本小程序仅提供夜郎秘境参考指南和信息展示。实际出行、探访、交通、住宿、露营、徒步、涉水、登山等活动，请以国家法律法规、行业规范以及当地政府、景区、社区和管理机构规定为准。
      </text>
      <text class="agreement-body">
        本小程序不提供任何安全保障、救援承诺或风险兜底。用户应自行评估天气、路线、身体状况、装备、交通和当地管制要求，所有安全责任由用户自行承担。
      </text>
      <button class="agreement-button" bindtap="onAcceptSafetyAgreement">我已阅读并同意</button>
    </view>
  </view>
</view>
