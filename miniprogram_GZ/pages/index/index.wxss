page {
  height: 100vh;
  overflow: hidden;
}

.page {
  height: 100vh;
  background: #f4f1e8;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.hero {
  position: relative;
  flex: none;
  height: 44vh;
  min-height: 400rpx;
  max-height: 620rpx;
  background: #dbe4d6;
}

.map {
  width: 100%;
  height: 100%;
}

.marker-canvas {
  /* Keep the drawing surface in the viewport. Some native map clients do not
     render an off-screen canvas, which leaves map markers without iconPath. */
  position: absolute;
  left: 0;
  top: 0;
  width: 40px;
  height: 50px;
  opacity: 0.01;
  pointer-events: none;
  z-index: 0;
}

.map-controls {
  position: absolute;
  left: 24rpx;
  bottom: 28rpx;
  z-index: 3;
  width: 218rpx;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  gap: 8rpx;
}

.map-control {
  width: 54rpx;
  height: 54rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.6);
  color: #193127;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 18rpx rgba(25, 49, 39, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.map-control.text {
  width: 104rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.sheet {
  position: relative;
  flex: 1;
  min-height: 0;
  margin-top: 0;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  border-radius: 8rpx 8rpx 0 0;
  background: #f8f6ef;
  box-shadow: 0 -12rpx 40rpx rgba(31, 49, 39, 0.12);
  box-sizing: border-box;
  z-index: 2;
  display: flex;
  flex-direction: column;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding-bottom: 4rpx;
  box-sizing: border-box;
}

.tag {
  flex: none;
  min-width: 72rpx;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  background: #ebe4d5;
  color: #5b635b;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag.active {
  background: #1f5f45;
  color: #ffffff;
}

.notice {
  margin: 4rpx 0 16rpx;
  color: #7a7468;
  font-size: 24rpx;
}

.level-section {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  flex: none;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.section-title {
  color: #193127;
  font-size: 26rpx;
  font-weight: 800;
}

.section-subtitle {
  color: #7a8079;
  font-size: 20rpx;
}

.level-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding-bottom: 4rpx;
}

.level-filter {
  min-width: 92rpx;
  height: 52rpx;
  padding: 0 12rpx;
  border: 1rpx solid #dfe4d9;
  border-radius: 8rpx;
  background: #ffffff;
  color: #526357;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.level-filter.active {
  border-color: #1f5f45;
  background: #e8f1e8;
  color: #1f5f45;
  font-weight: 700;
}

.level-color {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex: none;
}

.level-count {
  color: #7a8079;
  font-size: 19rpx;
  font-variant-numeric: tabular-nums;
}

.recommend-tag {
  color: #1f5f45;
  background: #e1f0e5;
  border: 1rpx solid #b9d6bf;
  font-weight: 700;
}

.summary-chips {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.spot-chip {
  max-width: 100%;
  padding: 8rpx 12rpx;
  border-radius: 7rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 21rpx;
  line-height: 1.25;
}

.spot-chip.unlocked {
  color: #1f5f45;
  background: #e5f1e7;
  border: 1rpx solid #b9d6bf;
}

.spot-chip.locked {
  color: #7b6651;
  background: #f6eee4;
  border: 1rpx solid #e1d1bd;
}

.chip-state {
  font-size: 18rpx;
  opacity: 0.78;
  flex: none;
}

.filter-summary {
  margin-top: 20px;
  padding: 10rpx 12rpx;
  border: 1rpx solid #dce8dc;
  border-radius: 8rpx;
  background: #f2f7f1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 14rpx;
  box-sizing: border-box;
}

.unlock-rule-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.unlock-rule-scroll {
  height: 260rpx;
  min-height: 0;
  padding-right: 6rpx;
  box-sizing: border-box;
}

.unlock-rule-list-inner {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-bottom: 4rpx;
}

.unlock-rule-card {
  padding: 18rpx 20rpx;
  border: 1rpx solid #c9dfcd;
  border-radius: 8rpx;
  background: #ffffff;
}

.unlock-rule-title,
.unlock-rule-body {
  display: block;
}

.unlock-rule-title {
  color: #1f5f45;
  font-size: 24rpx;
  font-weight: 800;
}

.unlock-rule-body {
  margin-top: 8rpx;
  color: #536357;
  font-size: 22rpx;
  line-height: 1.6;
}

.summary-copy {
  min-width: 0;
  flex: 1;
}

.summary-main,
.summary-count {
  display: block;
}

.summary-main {
  color: #244334;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-count {
  margin-top: 2rpx;
  color: #6d796e;
  font-size: 22rpx;
}

.results-button {
  width: 154rpx;
  height: 52rpx;
  margin: 0;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #1f5f45;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 52rpx;
  flex: none;
}

.nearby-search {
  flex: none;
  padding: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  box-sizing: border-box;
}

.nearby-label {
  color: #52705d;
  font-size: 19rpx;
  flex: none;
}

.radius-control {
  width: 116rpx;
  height: 48rpx;
  padding: 0 8rpx;
  border: 1rpx solid #c8dccd;
  border-radius: 7rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.radius-input {
  min-width: 0;
  flex: 1;
  color: #214735;
  font-size: 21rpx;
}

.radius-unit {
  color: #748178;
  font-size: 18rpx;
}

.nearby-button {
  min-width: 0;
  height: 52rpx;
  margin: 0;
  padding: 0 14rpx;
  border-radius: 7rpx;
  background: #537d67;
  color: #ffffff;
  font-size: 20rpx;
  line-height: 52rpx;
  flex: 1;
}

.radius-note {
  width: 100%;
  color: #6d796e;
  font-size: 20rpx;
}

.empty-filter {
  margin-top: 18rpx;
  color: #7a7468;
  font-size: 24rpx;
  text-align: center;
}

.agreement-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99;
  padding: 0 38rpx;
  background: rgba(16, 31, 24, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.agreement-panel {
  width: 100%;
  padding: 34rpx;
  border-radius: 8rpx;
  background: #fffdf8;
  box-shadow: 0 24rpx 80rpx rgba(16, 31, 24, 0.24);
  box-sizing: border-box;
}

.agreement-title,
.agreement-body {
  display: block;
}

.agreement-title {
  color: #193127;
  font-size: 36rpx;
  font-weight: 800;
}

.agreement-body {
  margin-top: 20rpx;
  color: #4e5d53;
  font-size: 26rpx;
  line-height: 1.6;
}

.agreement-button {
  height: 82rpx;
  margin-top: 28rpx;
  border-radius: 8rpx;
  background: #1f5f45;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agreement-button.secondary {
  margin-top: 16rpx;
  background: #eef2e8;
  color: #496251;
}
