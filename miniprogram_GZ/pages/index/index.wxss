page {
  height: 100vh;
  overflow: hidden;
}

.page {
  height: 100vh;
  background: #f4f1e8;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.nav-action {
  min-width: 72rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 28rpx;
  background: #193127;
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero {
  position: relative;
  flex: none;
  height: 52vh;
  min-height: 560rpx;
  max-height: 720rpx;
  background: #dbe4d6;
}

.map {
  width: 100%;
  height: 100%;
}

.marker-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  opacity: 0;
  pointer-events: none;
}

.map-controls {
  position: absolute;
  right: 24rpx;
  top: 20%;
  z-index: 3;
  width: 218rpx;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  gap: 8rpx;
}

.map-control {
  width: 54rpx;
  height: 54rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.6);
  color: #193127;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 18rpx rgba(25, 49, 39, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.map-control.text {
  width: 104rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.sheet {
  position: relative;
  flex: 1;
  min-height: 0;
  margin-top: 0;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 8rpx 8rpx 0 0;
  background: #f8f6ef;
  box-shadow: 0 -12rpx 40rpx rgba(31, 49, 39, 0.12);
  box-sizing: border-box;
  z-index: 2;
  display: flex;
  flex-direction: column;
}

.tag-scroll {
  width: 100%;
  height: 78rpx;
  white-space: nowrap;
  flex: none;
  display: block;
}

.tag-row {
  height: 78rpx;
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 18rpx;
  box-sizing: border-box;
}

.tag {
  flex: none;
  min-width: 92rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: #ebe4d5;
  color: #5b635b;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag.active {
  background: #1f5f45;
  color: #ffffff;
}

.notice {
  margin: 4rpx 0 16rpx;
  color: #7a7468;
  font-size: 24rpx;
}

.level-section {
  margin-top: 14rpx;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  color: #193127;
  font-size: 30rpx;
  font-weight: 800;
}

.section-subtitle {
  color: #7a8079;
  font-size: 22rpx;
}

.level-scroll {
  width: 100%;
  white-space: nowrap;
}

.level-row {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 6rpx;
}

.level-filter {
  min-width: 120rpx;
  height: 70rpx;
  padding: 0 16rpx;
  border: 1rpx solid #dfe4d9;
  border-radius: 8rpx;
  background: #ffffff;
  color: #526357;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.level-filter.active {
  border-color: #1f5f45;
  background: #e8f1e8;
  color: #1f5f45;
  font-weight: 700;
}

.level-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex: none;
}

.level-count {
  color: #7a8079;
  font-size: 22rpx;
  font-variant-numeric: tabular-nums;
}

.filter-summary {
  min-height: 76rpx;
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid #dce8dc;
  border-radius: 8rpx;
  background: #f2f7f1;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-sizing: border-box;
}

.summary-copy {
  min-width: 0;
  flex: 1;
}

.summary-main,
.summary-count {
  display: block;
}

.summary-main {
  color: #244334;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-count {
  margin-top: 2rpx;
  color: #6d796e;
  font-size: 22rpx;
}

.results-button {
  width: 154rpx;
  height: 52rpx;
  margin: 0;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #1f5f45;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 52rpx;
  flex: none;
}

.empty-filter {
  margin-top: 18rpx;
  color: #7a7468;
  font-size: 24rpx;
  text-align: center;
}

.agreement-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99;
  padding: 0 38rpx;
  background: rgba(16, 31, 24, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.agreement-panel {
  width: 100%;
  padding: 34rpx;
  border-radius: 8rpx;
  background: #fffdf8;
  box-shadow: 0 24rpx 80rpx rgba(16, 31, 24, 0.24);
  box-sizing: border-box;
}

.agreement-title,
.agreement-body {
  display: block;
}

.agreement-title {
  color: #193127;
  font-size: 36rpx;
  font-weight: 800;
}

.agreement-body {
  margin-top: 20rpx;
  color: #4e5d53;
  font-size: 26rpx;
  line-height: 1.6;
}

.agreement-button {
  height: 82rpx;
  margin-top: 28rpx;
  border-radius: 8rpx;
  background: #1f5f45;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agreement-button.secondary {
  margin-top: 16rpx;
  background: #eef2e8;
  color: #496251;
}
